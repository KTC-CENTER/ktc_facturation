{% extends 'base.html.twig' %}

{% block title %}Modifier {{ product.name }} - {{ app_name }}{% endblock %}

{% block content %}
<div class="space-y-6">
    <!-- En-tête -->
    <div class="flex items-center justify-between">
        <div>
            <nav class="text-sm text-gray-500 mb-2">
                <a href="{{ path('app_product_index') }}" class="hover:text-primary-600">Produits</a>
                <span class="mx-2">/</span>
                <a href="{{ path('app_product_show', {id: product.id}) }}" class="hover:text-primary-600">{{ product.name }}</a>
                <span class="mx-2">/</span>
                <span class="text-gray-700">Modifier</span>
            </nav>
            <h1 class="text-2xl font-bold text-gray-900">Modifier le produit</h1>
            <p class="mt-1 text-gray-500">{{ product.code }}</p>
        </div>
        <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-secondary">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Retour
        </a>
    </div>

    <!-- Formulaire partagé -->
    {{ include('product/_form.html.twig', {button_label: 'Enregistrer les modifications'}) }}
</div>
{% endblock %}
